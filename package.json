{
  "name": "siriux-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "clean": "lerna clean",
    "build": "lerna run build",
    "test": "lerna run test",
    "publish": "lerna publish",
    "dev": "lerna run dev --parallel",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --workspace=@siriux/docs\"",
    "start": "npm run dev:all"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "lerna": "^9.0.7"
  },
  "keywords": [
    "siriux",
    "monorepo",
    "saas",
    "starter-kit"
  ],
  "author": "jawwad@alsirius.co.uk",
  "license": "MIT",
  "description": "Siriux SaaS Starter Kit Monorepo"
}
