# ===========================================
# Siriux AI-Powered SaaS Configuration
# ===========================================
# Copy this file to .env and update with your values

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
PORT=3000
DOCS_PORT=5173

# ===========================================
# Database Configuration
# ===========================================
# Choose your database type:
# - in-memory (default for development) - Fast in-memory database, no setup required
# - postgresql (recommended for production) - PostgreSQL database
# - snowflake-real - Real Snowflake connection
# - snowflake-mock - Simulated Snowflake for demos
# - sqlite - File-based SQL database
MOCK_DB_TYPE=in-memory

# ===========================================
# PostgreSQL Configuration (Recommended for production)
# ===========================================
# Get these from your PostgreSQL database
PGHOST=localhost
PGPORT=5432
PGDATABASE=siriux
PGUSER=postgres
PGPASSWORD=your-postgres-password
PGSSL=false
PG_MAX_CONNECTIONS=20
PG_IDLE_TIMEOUT=30000
PG_CONNECTION_TIMEOUT=2000

# Alternative database configuration names (for compatibility)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=siriux
DATABASE_USER=postgres
DATABASE_PASSWORD=your-postgres-password
DATABASE_SSL=false

# ===========================================
# Snowflake Configuration (Required for real connection)
# ===========================================
# Get these from your Snowflake account
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USERNAME=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=SIRIUX_WAREHOUSE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_DATABASE=SIRIUX_DEMO
SNOWFLAKE_ROLE=SIRIUX_ADMIN
SNOWFLAKE_KEEP_ALIVE=true

# ===========================================
# Authentication Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ===========================================
# Mock Configuration
# ===========================================
# Force mock mode (development only)
SIRIUX_MOCK_MODE=true

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=info
LOG_OUTPUTS=console,database
LOGGING_ENABLE_METRICS=true

# ===========================================
# Configuration Management
# ===========================================
CONFIG_STORAGE=memory
CONFIG_VALIDATION=true
CONFIG_CACHING=true

# ===========================================
# Access Control Configuration
# ===========================================
ACCESS_CONTROL_CACHING=true
ACCESS_CONTROL_AUDIT=true
DEFAULT_EFFECT=deny

# ===========================================
# Development Tools
# ===========================================
# Enable hot reload
FAST_REFRESH=true

# Enable debug mode
DEBUG=siriux:*

# ===========================================
# Production Configuration
# ===========================================
# Uncomment these for production deployment
# NODE_ENV=production
# MOCK_DB_TYPE=snowflake-real
# LOG_LEVEL=warn
# LOG_OUTPUTS=database,cloud
# CONFIG_STORAGE=database
# SIRIUX_MOCK_MODE=false

# ===========================================
# Optional: External Services
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=your-ga-id

# Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn

# Stripe Payment Processing
# STRIPE_PUBLISHABLE_KEY=pk_test_your-key
# STRIPE_SECRET_KEY=sk_test_your-key

# Email Service
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ===========================================
# AI Configuration (Future)
# ===========================================
# OpenAI API Key
# OPENAI_API_KEY=your-openai-key

# Anthropic API Key
# ANTHROPIC_API_KEY=your-anthropic-key

# ===========================================
# Quick Start Commands
# ===========================================
# 1. Copy this file: cp .env.example .env
# 2. Update values above (optional for demo)
# 3. Install dependencies: npm install
# 4. Start development: npm run dev:all
# 5. Open browser: http://localhost:3000

